# PocketBase URL (auth + database)
# Local dev: http://127.0.0.1:8090
# Production: https://your-domain.com or http://droplet-ip:8090
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# OpenRouter (server-side only — used by Python backend)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# PocketBase admin URL for server-side token verification
# (used by Python backend to validate user tokens)
POCKETBASE_URL=http://127.0.0.1:8090
